<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LaLiga Standings</title>
<style>
body {
    font-family: Arial, sans-serif;
    background: #0b1c2c;
    color: white;
}

.container {
    width: 700px;
    margin: 40px auto;
    background: #0f2a3f;
    border-radius: 10px;
    overflow: hidden;
}

.header {
    background: red;
    padding: 15px;
    text-align: center;
    font-weight: bold;
    font-size: 22px;
}

table {
    width: 100%;
    border-collapse: collapse;
}

th, td {
    padding: 10px;
    text-align: left;
}

th {
    background: #122f46;
}

tr {
    border-bottom: 1px solid #1f3f5a;
}

tr:hover {
    background: #163d5c;
}

.rank {
    width: 30px;
}

.team {
    font-weight: bold;
}

.stats {
    text-align: center;
}
</style>
</head>

<body>

<div class="container">
    <div class="header">STANDINGS</div>

    <table>
        <thead>
